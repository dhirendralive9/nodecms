<%- include('../../partials/admin-header') %>

<div class="admin-header-bar">
  <h1><%= action === 'new' ? 'New Post' : 'Edit Post' %></h1>
  <a href="/admin/posts" class="btn btn-ghost">← Back to Posts</a>
</div>

<form method="POST" action="<%= action === 'new' ? '/admin/posts' : '/admin/posts/' + post._id %>" id="postForm">
  <div class="editor-layout">
    <div class="editor-main">
      <div class="form-group">
        <input type="text" name="title" value="<%= post ? post.title : '' %>" placeholder="Post title" class="input-title" required>
      </div>

      <% if (post) { %>
      <div class="form-group">
        <label>Slug</label>
        <input type="text" name="slug" value="<%= post.slug %>" class="form-control">
      </div>
      <% } %>

      <div class="form-group">
        <label>Content</label>
        <div id="quill-editor" class="quill-container"><%= post ? post.content : '' %></div>
        <input type="hidden" name="content" id="content-field">
      </div>

      <div class="form-group">
        <label>Excerpt</label>
        <textarea name="excerpt" rows="3" class="form-control" placeholder="Brief description..."><%= post ? post.excerpt : '' %></textarea>
      </div>
    </div>

    <div class="editor-sidebar">
      <div class="sidebar-panel">
        <h3>Publish</h3>
        <div class="form-group">
          <label>Status</label>
          <select name="status" class="form-control">
            <option value="draft" <%= post && post.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="published" <%= post && post.status === 'published' ? 'selected' : '' %>>Published</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-full">
          <%= action === 'new' ? 'Create Post' : 'Update Post' %>
        </button>
      </div>

      <div class="sidebar-panel">
        <h3>Featured Image</h3>
        <div class="form-group">
          <input type="text" name="featuredImage" value="<%= post ? post.featuredImage : '' %>" placeholder="/uploads/image.jpg" class="form-control" id="featuredImageInput">
          <button type="button" class="btn btn-sm btn-full" onclick="openMediaPicker('featuredImageInput')" style="margin-top:0.5rem">Choose Image</button>
          <div id="featuredImagePreview" style="margin-top:0.5rem">
            <% if (post && post.featuredImage) { %>
              <img src="<%= post.featuredImage %>" style="max-width:100%;border-radius:6px">
            <% } %>
          </div>
        </div>
      </div>

      <div class="sidebar-panel">
        <h3>Categories & Tags</h3>
        <div class="form-group">
          <label>Categories</label>
          <input type="text" name="categories" value="<%= post ? post.categories.join(', ') : '' %>" placeholder="tech, news, tutorial" class="form-control">
          <small>Comma separated</small>
        </div>
        <div class="form-group">
          <label>Tags</label>
          <input type="text" name="tags" value="<%= post ? post.tags.join(', ') : '' %>" placeholder="javascript, nodejs" class="form-control">
          <small>Comma separated</small>
        </div>
      </div>

      <div class="sidebar-panel">
        <h3>SEO</h3>
        <div class="form-group">
          <label>Meta Title</label>
          <input type="text" name="metaTitle" value="<%= post && post.seo ? post.seo.metaTitle : '' %>" class="form-control" placeholder="SEO title">
        </div>
        <div class="form-group">
          <label>Meta Description</label>
          <textarea name="metaDescription" rows="2" class="form-control" placeholder="SEO description"><%= post && post.seo ? post.seo.metaDescription : '' %></textarea>
        </div>
      </div>

      <div class="sidebar-panel">
        <h3>Code Injection</h3>
        <p style="font-size:0.75rem;color:#64748b;margin-bottom:0.75rem">Custom code for this post only. Stacks with global code from Settings.</p>
        <div class="form-group">
          <label>Head Code</label>
          <textarea name="headCode" rows="3" class="form-control" style="font-family:monospace;font-size:0.8rem" placeholder="<style>, <script>, <meta> etc."><%= post && post.codeInjection ? post.codeInjection.headCode : '' %></textarea>
        </div>
        <div class="form-group">
          <label>Body Code</label>
          <textarea name="bodyCode" rows="3" class="form-control" style="font-family:monospace;font-size:0.8rem" placeholder="Scripts before </body>"><%= post && post.codeInjection ? post.codeInjection.bodyCode : '' %></textarea>
        </div>
      </div>
    </div>
  </div>
</form>

<!-- Media Picker Modal -->
<div id="mediaPickerModal" class="modal" style="display:none">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Select Image</h2>
      <button onclick="closeMediaPicker()" class="btn btn-ghost">&times;</button>
    </div>
    <div id="mediaPickerGrid" class="media-grid"></div>
  </div>
</div>

<!-- Quill CSS/JS -->
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  // Initialize Quill
  const quill = new Quill('#quill-editor', {
    theme: 'snow',
    placeholder: 'Write your post content here...',
    modules: {
      toolbar: [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['blockquote', 'code-block'],
        ['link', 'image'],
        [{ align: [] }],
        ['clean']
      ]
    }
  });

  // Load existing content
  <% if (post && post.content) { %>
    quill.root.innerHTML = `<%- post.content.replace(/`/g, '\\`').replace(/\\/g, '\\\\') %>`;
  <% } %>

  // Sync Quill to hidden field on submit
  document.getElementById('postForm').addEventListener('submit', function() {
    document.getElementById('content-field').value = quill.root.innerHTML;
  });

  // Media Picker
  let activeMediaTarget = null;

  function openMediaPicker(targetId) {
    activeMediaTarget = targetId;
    document.getElementById('mediaPickerModal').style.display = 'flex';
    fetch('/admin/media/api/list')
      .then(r => r.json())
      .then(files => {
        const grid = document.getElementById('mediaPickerGrid');
        grid.innerHTML = files.map(f =>
          `<div class="media-item" onclick="selectMedia('${f.url}')">
            <img src="${f.url}" alt="${f.alt || f.originalName}">
            <span>${f.originalName}</span>
          </div>`
        ).join('') || '<p style="padding:2rem;color:#64748b">No images uploaded yet</p>';
      });
  }

  function selectMedia(url) {
    document.getElementById(activeMediaTarget).value = url;
    if (activeMediaTarget === 'featuredImageInput') {
      document.getElementById('featuredImagePreview').innerHTML = `<img src="${url}" style="max-width:100%;border-radius:6px">`;
    }
    closeMediaPicker();
  }

  function closeMediaPicker() {
    document.getElementById('mediaPickerModal').style.display = 'none';
  }
</script>

<%- include('../../partials/admin-footer') %>
