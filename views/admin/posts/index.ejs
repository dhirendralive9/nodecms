<%- include('../../partials/admin-header') %>

<div class="admin-header-bar">
  <h1>Posts</h1>
  <a href="/admin/posts/new" class="btn btn-primary">+ New Post</a>
</div>

<div class="admin-card">
  <div class="card-toolbar">
    <div class="filter-tabs">
      <a href="/admin/posts" class="<%= !status ? 'active' : '' %>">All</a>
      <a href="/admin/posts?status=published" class="<%= status === 'published' ? 'active' : '' %>">Published</a>
      <a href="/admin/posts?status=draft" class="<%= status === 'draft' ? 'active' : '' %>">Drafts</a>
    </div>
    <form class="search-bar" action="/admin/posts" method="GET">
      <input type="text" name="search" value="<%= search %>" placeholder="Search posts...">
      <button type="submit" class="btn btn-sm">Search</button>
    </form>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Categories</th>
        <th>Status</th>
        <th>Date</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (posts.length === 0) { %>
        <tr><td colspan="6" class="empty-state">No posts found</td></tr>
      <% } %>
      <% posts.forEach(post => { %>
        <tr>
          <td><strong><a href="/admin/posts/<%= post._id %>/edit"><%= post.title %></a></strong></td>
          <td><%= post.author ? (post.author.displayName || post.author.username) : '—' %></td>
          <td><%= post.categories.join(', ') || '—' %></td>
          <td><span class="badge badge-<%= post.status %>"><%= post.status %></span></td>
          <td><%= post.createdAt.toLocaleDateString() %></td>
          <td class="actions">
            <a href="/admin/posts/<%= post._id %>/edit" class="btn btn-sm">Edit</a>
            <form method="POST" action="/admin/posts/<%= post._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this post?')">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/admin/posts?page=<%= i %>&status=<%= status %>&search=<%= search %>" class="<%= i === page ? 'active' : '' %>"><%= i %></a>
      <% } %>
    </div>
  <% } %>
</div>

<%- include('../../partials/admin-footer') %>
