<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Password | NodeCMS</title>
  <link rel="stylesheet" href="/css/admin.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="login-body">
  <div class="login-container">
    <div class="login-card">
      <div class="login-brand">
        <svg width="40" height="40" viewBox="0 0 28 28" fill="none"><rect width="28" height="28" rx="6" fill="#2563eb"/><path d="M8 8h4v12H8V8zm8 4h4v8h-4v-8z" fill="#fff"/></svg>
        <h1>Reset Password</h1>
        <p>Enter your email to receive a reset link</p>
      </div>
      <% if (success) { %>
        <div class="alert alert-success"><%= success %></div>
      <% } %>
      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/admin/forgot-password">
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required autofocus placeholder="you@example.com">
        </div>
        <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
      </form>
      <div style="text-align:center;margin-top:1rem">
        <a href="/admin/login" style="font-size:0.85rem;color:#64748b;text-decoration:none">← Back to login</a>
      </div>
    </div>
  </div>
</body>
</html>
