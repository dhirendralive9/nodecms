<%- include('../../partials/admin-header') %>

<div class="admin-header-bar">
  <h1><%= action === 'new' ? 'New Page' : 'Edit Page' %></h1>
  <a href="/admin/pages" class="btn btn-ghost">← Back to Pages</a>
</div>

<form method="POST" action="<%= action === 'new' ? '/admin/pages' : '/admin/pages/' + page._id %>" id="pageForm">
  <div class="editor-layout">
    <div class="editor-main">
      <div class="form-group">
        <input type="text" name="title" value="<%= page ? page.title : '' %>" placeholder="Page title" class="input-title" required>
      </div>
      <% if (page) { %>
      <div class="form-group">
        <label>Slug</label>
        <input type="text" name="slug" value="<%= page.slug %>" class="form-control">
      </div>
      <% } %>
      <div class="form-group">
        <label>Content</label>
        <div id="quill-editor" class="quill-container"><%= page ? page.content : '' %></div>
        <input type="hidden" name="content" id="content-field">
      </div>
    </div>
    <div class="editor-sidebar">
      <div class="sidebar-panel">
        <h3>Publish</h3>
        <div class="form-group">
          <label>Status</label>
          <select name="status" class="form-control">
            <option value="draft" <%= page && page.status === 'draft' ? 'selected' : '' %>>Draft</option>
            <option value="published" <%= page && page.status === 'published' ? 'selected' : '' %>>Published</option>
          </select>
        </div>
        <div class="form-group">
          <label>Template</label>
          <select name="template" class="form-control">
            <option value="default" <%= page && page.template === 'default' ? 'selected' : '' %>>Default</option>
            <option value="full-width" <%= page && page.template === 'full-width' ? 'selected' : '' %>>Full Width</option>
            <option value="landing" <%= page && page.template === 'landing' ? 'selected' : '' %>>Landing Page</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary btn-full">
          <%= action === 'new' ? 'Create Page' : 'Update Page' %>
        </button>
      </div>
      <div class="sidebar-panel">
        <h3>Featured Image</h3>
        <div class="form-group">
          <input type="text" name="featuredImage" value="<%= page ? page.featuredImage : '' %>" placeholder="/uploads/image.jpg" class="form-control">
        </div>
      </div>
      <div class="sidebar-panel">
        <h3>SEO</h3>
        <div class="form-group">
          <label>Meta Title</label>
          <input type="text" name="metaTitle" value="<%= page && page.seo ? page.seo.metaTitle : '' %>" class="form-control">
        </div>
        <div class="form-group">
          <label>Meta Description</label>
          <textarea name="metaDescription" rows="2" class="form-control"><%= page && page.seo ? page.seo.metaDescription : '' %></textarea>
        </div>
      </div>

      <div class="sidebar-panel">
        <h3>Code Injection</h3>
        <p style="font-size:0.75rem;color:#64748b;margin-bottom:0.75rem">Custom code for this page only.</p>
        <div class="form-group">
          <label>Head Code</label>
          <textarea name="headCode" rows="3" class="form-control" style="font-family:monospace;font-size:0.8rem" placeholder="<style>, <script>, <meta> etc."><%= page && page.codeInjection ? page.codeInjection.headCode : '' %></textarea>
        </div>
        <div class="form-group">
          <label>Body Code</label>
          <textarea name="bodyCode" rows="3" class="form-control" style="font-family:monospace;font-size:0.8rem" placeholder="Scripts before </body>"><%= page && page.codeInjection ? page.codeInjection.bodyCode : '' %></textarea>
        </div>
      </div>
    </div>
  </div>
</form>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
  const quill = new Quill('#quill-editor', {
    theme: 'snow',
    placeholder: 'Write your page content...',
    modules: {
      toolbar: [
        [{ header: [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['blockquote', 'code-block'],
        ['link', 'image'],
        [{ align: [] }],
        ['clean']
      ]
    }
  });
  <% if (page && page.content) { %>
    quill.root.innerHTML = `<%- page.content.replace(/`/g, '\\`').replace(/\\/g, '\\\\') %>`;
  <% } %>
  document.getElementById('pageForm').addEventListener('submit', function() {
    document.getElementById('content-field').value = quill.root.innerHTML;
  });
</script>

<%- include('../../partials/admin-footer') %>
