<%- include('partials/header') %>

<main class="site-main">
  <div class="container content-layout<%= theme.components.showSidebar ? ' with-sidebar sidebar-' + theme.layout.sidebarPosition : '' %>">
    <div class="content-area">
      <header class="archive-header">
        <h1>Search<%= query ? ': ' + query : '' %></h1>
      </header>
      <form action="/search" method="GET" class="search-form-large">
        <input type="text" name="q" value="<%= query %>" placeholder="Search posts..." autofocus>
        <button type="submit" class="btn-search">Search</button>
      </form>
      <% if (query && posts.length === 0) { %>
        <p class="no-results">No results found for "<%= query %>"</p>
      <% } %>
      <div class="posts-grid">
        <% posts.forEach(post => { %>
          <article class="post-card">
            <div class="post-card-body">
              <h2 class="post-card-title"><a href="/post/<%= post.slug %>"><%= post.title %></a></h2>
              <p class="post-card-excerpt"><%= post.excerpt %></p>
              <div class="post-meta">
                <span class="meta-date"><%= (post.publishedAt || post.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
    <%- include('partials/sidebar') %>
  </div>
</main>

<%- include('partials/footer') %>
