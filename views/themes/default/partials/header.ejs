<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (typeof page !== 'undefined' && page.seo && page.seo.metaTitle) { %>
    <title><%= page.seo.metaTitle %></title>
  <% } else if (typeof post !== 'undefined' && post.seo && post.seo.metaTitle) { %>
    <title><%= post.seo.metaTitle %></title>
  <% } else { %>
    <title><%= typeof page !== 'undefined' && page.title ? page.title + ' | ' : '' %><%= site.title %></title>
  <% } %>
  <% if ((typeof post !== 'undefined' && post.seo && post.seo.metaDescription) || (typeof page !== 'undefined' && page.seo && page.seo.metaDescription)) { %>
    <meta name="description" content="<%= (post && post.seo && post.seo.metaDescription) || (page && page.seo && page.seo.metaDescription) %>">
  <% } else if (site.tagline) { %>
    <meta name="description" content="<%= site.tagline %>">
  <% } %>
  <% if (site.favicon) { %><link rel="icon" href="<%= site.favicon %>"><% } %>

  <!-- Theme Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Theme CSS Variables from theme.json -->
  <style>
    :root {
      --color-primary: <%= theme.colors.primary %>;
      --color-primary-hover: <%= theme.colors.primaryHover || theme.colors.primary %>;
      --color-secondary: <%= theme.colors.secondary %>;
      --color-accent: <%= theme.colors.accent %>;
      --color-bg: <%= theme.colors.background %>;
      --color-surface: <%= theme.colors.surface %>;
      --color-surface-alt: <%= theme.colors.surfaceAlt || theme.colors.surface %>;
      --color-text: <%= theme.colors.text %>;
      --color-text-muted: <%= theme.colors.textMuted %>;
      --color-text-light: <%= theme.colors.textLight || theme.colors.textMuted %>;
      --color-border: <%= theme.colors.border %>;
      --color-header-bg: <%= theme.colors.headerBg || '#0f172a' %>;
      --color-header-text: <%= theme.colors.headerText || '#f8fafc' %>;
      --color-footer-bg: <%= theme.colors.footerBg || '#1e293b' %>;
      --color-footer-text: <%= theme.colors.footerText || '#cbd5e1' %>;
      --font-heading: <%= theme.typography.headingFont %>;
      --font-body: <%= theme.typography.bodyFont %>;
      --font-mono: <%= theme.typography.monoFont || 'monospace' %>;
      --font-size-base: <%= theme.typography.baseSize %>;
      --line-height: <%= theme.typography.lineHeight %>;
      --max-width: <%= theme.layout.maxWidth %>;
      --content-width: <%= theme.layout.contentWidth || '800px' %>;
      --sidebar-width: <%= theme.layout.sidebarWidth %>;
      --radius: <%= theme.layout.borderRadius || '8px' %>;
      --gap: <%= theme.layout.gridGap || '2rem' %>;
    }
  </style>
  <link rel="stylesheet" href="/css/theme.css">
  <% if (theme.custom && theme.custom.customCSS) { %>
    <style><%= theme.custom.customCSS %></style>
  <% } %>
  <% if (theme.custom && theme.custom.headScripts) { %>
    <%- theme.custom.headScripts %>
  <% } %>

  <%/* Global code injection from Settings */%>
  <% if (site.globalHeadCode) { %>
    <%- site.globalHeadCode %>
  <% } %>

  <%/* Per-post/page code injection */%>
  <% if (typeof post !== 'undefined' && post && post.codeInjection && post.codeInjection.headCode) { %>
    <%- post.codeInjection.headCode %>
  <% } %>
  <% if (typeof page !== 'undefined' && page && page.codeInjection && page.codeInjection.headCode) { %>
    <%- page.codeInjection.headCode %>
  <% } %>
</head>
<body>
  <!-- Header -->
  <header class="site-header<%= theme.layout.headerPosition === 'sticky' ? ' sticky' : '' %>">
    <div class="container header-inner">
      <div class="site-brand">
        <% if (site.logo) { %>
          <a href="/"><img src="<%= site.logo %>" alt="<%= site.title %>" class="site-logo"></a>
        <% } else { %>
          <a href="/" class="site-title"><%= site.title %></a>
        <% } %>
        <% if (site.tagline) { %>
          <span class="site-tagline"><%= site.tagline %></span>
        <% } %>
      </div>
      <nav class="site-nav">
        <% if (menus.primary) { %>
          <% menus.primary.forEach(item => { %>
            <% if (item.children && item.children.length > 0) { %>
              <div class="nav-dropdown <%= currentPath === item.url ? 'active' : '' %> <%= item.cssClass || '' %>">
                <a href="<%= item.url %>" target="<%= item.target %>" class="nav-dropdown-trigger">
                  <% if (item.icon) { %><span class="nav-icon"><%- item.icon %></span><% } %>
                  <%= item.label %>
                  <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </a>
                <div class="nav-dropdown-menu">
                  <% item.children.sort((a,b) => a.order - b.order).forEach(child => { %>
                    <a href="<%= child.url %>" target="<%= child.target || '_self' %>" class="<%= child.cssClass || '' %>">
                      <% if (child.icon) { %><span class="nav-icon"><%- child.icon %></span><% } %>
                      <%= child.label %>
                    </a>
                  <% }) %>
                </div>
              </div>
            <% } else { %>
              <a href="<%= item.url %>" target="<%= item.target %>" class="<%= currentPath === item.url ? 'active' : '' %> <%= item.cssClass || '' %>">
                <% if (item.icon) { %><span class="nav-icon"><%- item.icon %></span><% } %>
                <%= item.label %>
              </a>
            <% } %>
          <% }) %>
        <% } %>
        <% if (theme.components.showSearch) { %>
          <a href="/search" class="nav-search-btn" title="Search">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </a>
        <% } %>
      </nav>
      <button class="mobile-menu-toggle" onclick="document.querySelector('.site-nav').classList.toggle('open')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </header>
  <script>
    // Mobile dropdown toggle
    document.querySelectorAll('.nav-dropdown-trigger').forEach(trigger => {
      trigger.addEventListener('click', function(e) {
        if (window.innerWidth <= 768) {
          e.preventDefault();
          this.parentElement.classList.toggle('mobile-open');
        }
      });
    });
  </script>
