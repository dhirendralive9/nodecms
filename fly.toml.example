# fly.toml - Fly.io deployment config
# Run: fly launch --no-deploy
# Then: fly secrets set MONGODB_URI="mongodb+srv://..." SESSION_SECRET="your-secret"
# Then: fly deploy

app = "nodecms"
primary_region = "iad"

[build]

[env]
  NODE_ENV = "production"
  PORT = "8080"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  memory = "512mb"
  cpu_kind = "shared"
  cpus = 1
