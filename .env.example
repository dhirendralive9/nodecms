# NodeCMS Configuration
PORT=3000
MONGODB_URI=mongodb://localhost:27017/nodecms
SESSION_SECRET=change-this-to-a-random-secret-key
SITE_URL=http://localhost:3000
NODE_ENV=development

# ─── SMTP / Email ────────────────────────────────────────
# Set these in .env or as environment variables on your hosting platform
# Works with any SMTP: Gmail, SendGrid, Mailgun, AWS SES, your own server, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_NAME=NodeCMS
SMTP_FROM_EMAIL=noreply@yourdomain.com

# ─── Production Notes ────────────────────────────────────
# MONGODB_URI    → Use MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/nodecms
# SESSION_SECRET → Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SITE_URL       → Your public URL: https://yourdomain.com
# NODE_ENV       → Set to "production" for deployed environments
# SMTP           → Gmail: enable 2FA, create App Password. SendGrid: use apikey as user, key as pass.
