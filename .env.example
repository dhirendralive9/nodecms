# NodeCMS Configuration
PORT=3000
MONGODB_URI=mongodb://localhost:27017/nodecms
SESSION_SECRET=change-this-to-a-random-secret-key
SITE_URL=http://localhost:3000
NODE_ENV=development

# ─── Production Notes ────────────────────────────────────
# MONGODB_URI  → Use MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/nodecms
# SESSION_SECRET → Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SITE_URL → Your public URL: https://yourdomain.com
# NODE_ENV → Set to "production" for deployed environments
